# Telegram
BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=123456789,987654321

# LLM Provider: openai, gigachat, yandex, ollama
LLM_PROVIDER=gigachat

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# GigaChat
GIGACHAT_CREDENTIALS=your_gigachat_auth_token
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# YandexGPT
YANDEX_API_KEY=your-yandex-api-key
YANDEX_FOLDER_ID=your-yandex-folder-id

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Embedding model
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# For local embedding via Ollama: OLLAMA_EMBEDDING_MODEL=qwen2.5:7b

# FAISS index
FAISS_INDEX_PATH=data/faiss_index

# Knowledge base directory
KNOWLEDGE_DIR=data/knowledge

# Database
DB_PATH=data/bot.db

# Google Calendar
GOOGLE_CALENDAR_CRED=data/google_credentials.json
GOOGLE_CALENDAR_TOKEN=data/google_token.json
GOOGLE_CALENDAR_ID=primary

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/bot.log
